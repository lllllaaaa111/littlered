# ============================================================
# 小红书自动运营 Agent — 环境变量配置
# 使用方法：复制本文件为 .env，填写实际值后运行 docker-compose up
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=xiaohongshu_agent
DB_HOST=postgres
DB_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── LLM API（OpenAI 兼容接口） ────────────────────────────
LLM_API_KEY=sk-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.8
LLM_MAX_RETRIES=3

# ── Stable Diffusion API ──────────────────────────────────
# 宿主机本地 SD WebUI：使用 host.docker.internal
# 云端 SD API：填写实际地址
SD_API_URL=http://host.docker.internal:7860
SD_STEPS=30
SD_CFG_SCALE=7
SD_WIDTH=1024
SD_HEIGHT=1024
SD_SAMPLER=DPM++ 2M Karras

# ── 小红书账号 ────────────────────────────────────────────
XHS_USERNAME=your_phone_number
XHS_PASSWORD=your_password
XHS_PUBLISH_INTERVAL=120

# ── 定时调度 ──────────────────────────────────────────────
DAILY_POST_COUNT=30
GENERATE_TIME=08:00
PUBLISH_TIME=09:00
COLLECT_TIME=18:00
OPTIMIZE_TIME=23:00
