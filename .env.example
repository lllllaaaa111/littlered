## Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/xhs_agent

## Xiaohongshu automation
XHS_BASE_URL=https://www.xiaohongshu.com
XHS_STORAGE_STATE_PATH=storage_state.json
XHS_HEADLESS=false

## LLM (optional; used for better topic/post generation)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Stable Diffusion (Diffusers)
SD_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
SD_DEVICE=cuda
SD_DTYPE=float16
SD_NUM_INFERENCE_STEPS=30
SD_GUIDANCE_SCALE=7.0
SD_SEED=

## Runtime
OUTPUT_DIR=outputs
LOG_LEVEL=INFO

