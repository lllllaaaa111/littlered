# ── Git ──────────────────────────────────────────────────
.git
.gitignore

# ── Python 缓存 ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── 虚拟环境 ──────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── 运行时数据（使用 Docker Volume 挂载） ─────────────────
storage/
logs/
cookies/
chroma_data/

# ── 敏感文件 ──────────────────────────────────────────────
.env
config/config.yaml

# ── 测试 ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/

# ── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 系统文件 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# ── Docker 文件（避免循环） ───────────────────────────────
docker-compose*.yml
Dockerfile*
