## Database
# PostgreSQL (需要 Docker 或本地安装)
DATABASE_URL=postgresql+psycopg://postgres:123@localhost:5432/xhs_agent

# SQLite 本地测试（无需 Docker）
# DATABASE_URL=sqlite:///./xhs_agent.db

## Xiaohongshu automation
XHS_BASE_URL=https://www.xiaohongshu.com
XHS_STORAGE_STATE_PATH=storage_state.json
XHS_HEADLESS=false

## LLM (optional; used for better topic/post generation)
LLM_PROVIDER=openai
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/chat/completions 
OPENAI_API_KEY=65f103cc5dd84f9d9b83fd242857310e.cy8Jqs4dO85QBV8i
OPENAI_MODEL=glm-4.6v

## Stable Diffusion (Diffusers)
SD_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
SD_DEVICE=cpu
SD_DTYPE=float16
SD_NUM_INFERENCE_STEPS=30
SD_GUIDANCE_SCALE=7.0
SD_SEED=42

## Runtime
OUTPUT_DIR=outputs
LOG_LEVEL=INFO

